{
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "forceConsistentCasingInFileNames": true,
        /* Paths */
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./apps/web/src/*"
            ],
            "@njupt-search/contracts": [
                "./packages/contracts/src/index.ts"
            ],
            "@njupt-search/contracts/exam": [
                "./packages/contracts/src/exam/index.ts"
            ],
            "@njupt-search/contracts/search-index": [
                "./packages/contracts/src/search-index/index.ts"
            ],
            "@njupt-search/contracts/source-sitegraph": [
                "./packages/contracts/src/source-sitegraph/index.ts"
            ],
            "@njupt-search/search-core": [
                "./packages/search-core/src/index.ts"
            ],
            "@njupt-search/exam-core": [
                "./packages/exam-core/src/index.ts"
            ],
            "@njupt-search/exam-core/calendar": [
                "./packages/exam-core/src/calendar/index.ts"
            ],
            "@njupt-search/exam-core/contract": [
                "./packages/exam-core/src/contract/index.ts"
            ],
            "@njupt-search/exam-core/search": [
                "./packages/exam-core/src/search/index.ts"
            ]
        }
    },
    "include": [
        "apps/web/src",
        "packages/contracts/src",
        "packages/search-core/src",
        "packages/exam-core/src"
    ]
}
